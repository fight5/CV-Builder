# Streamlit Cloud secrets template.
#
# Local dev: this file is ignored. Use .env at the project root instead.
#
# Cloud deploy: copy these keys into your app's Secrets panel on
# https://share.streamlit.io (your app → Settings → Secrets) and paste your
# real values. Streamlit injects them as st.secrets at runtime.

GOOGLE_API_KEY = "your_gemini_api_key_here"
GEMINI_MODEL = "gemini-2.5-flash"
