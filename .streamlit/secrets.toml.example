# Copiez ce fichier en secrets.toml et renseignez vos clés API.
# Sur Streamlit Cloud : Settings → Secrets → coller le contenu ci-dessous.

GOOGLE_API_KEY = "votre_cle_gemini_ici"
GEMINI_MODEL   = "gemini-2.5-flash"

# DeepSeek (optionnel, prioritaire sur Gemini si renseigné)
# DEEPSEEK_API_KEY = "votre_cle_deepseek_ici"
# DEEPSEEK_MODEL   = "deepseek-chat"

# Mettre "cloud" pour désactiver la page Candidature automatique
# (Playwright n'est pas disponible sur Streamlit Cloud)
DEPLOYMENT_MODE = "cloud"
